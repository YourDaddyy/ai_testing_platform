# ============================================================
# Environment Variables Template
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to Git.
# ============================================================

# ── AI ────────────────────────────────────────────────────────────────────────
# Claude / Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# (Optional) Local/intranet LLM proxy URL
# LOCAL_LLM_API_URL=http://localhost:11434/api/generate

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="CRM 测试与 AI 分析平台"

# ── SSH Log Query Credentials ─────────────────────────────────────────────────
# Fill in each system's SSH host, port, username, and password.
# BSSP_LOG_PATHS / SAC_LOG_PATHS / TE_LOG_PATHS:
#   Comma-separated log file paths. Leave empty for auto-detection.

# BSSP
BSSP_SSH_HOST=your_bssp_host_ip
BSSP_SSH_PORT=22
BSSP_SSH_USER=your_bssp_username
BSSP_SSH_PASS=your_bssp_password
BSSP_LOG_PATHS=

# SAC
SAC_SSH_HOST=your_sac_host_ip
SAC_SSH_PORT=22
SAC_SSH_USER=your_sac_username
SAC_SSH_PASS=your_sac_password
SAC_LOG_PATHS=

# TE
TE_SSH_HOST=your_te_host_ip
TE_SSH_PORT=22
TE_SSH_USER=your_te_username
TE_SSH_PASS=your_te_password
TE_LOG_PATHS=

# ── Launcher ──────────────────────────────────────────────────────────────────
# Path to Chrome executable. Leave empty to use system default browser.
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Mac:     /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
CHROME_PATH=
